# ─── SSI Pipeline — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your credentials.
# The pipeline uses python-dotenv to load this automatically.
#
# Run `python run_pipeline.py --synthetic` to test WITHOUT any keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── CDS API (ERA5 / ERA5-Land climate data) ──────────────────────────────────
# Standard cdsapi reads from C:\Users\<you>\.cdsapirc — no env var needed.
# Format of .cdsapirc:
#   url: https://cds.climate.copernicus.eu/api/v2
#   key: UID:API_KEY
# Register at: https://cds.climate.copernicus.eu/user/register
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2
CDS_API_KEY=94575ab9-1f53-4079-afbb-532722c2e7b3

# ── Microsoft Planetary Computer (Sentinel-2 NDVI, MODIS LST) ────────────────
# Leave empty for anonymous SAS token access (works for research volumes).
# Request a subscription token at: https://planetarycomputer.microsoft.com/account/request
PLANETARY_COMPUTER_API_KEY=

# ── NASA EarthData (SEDAC PM2.5 global data) ─────────────────────────────────
# Register at: https://urs.earthdata.nasa.gov/users/new
# Required for automated SEDAC downloads. Manual download also works.
EARTHDATA_USERNAME=aryanghanwat
EARTHDATA_PASSWORD=StressIndex@123

# ── CAMS ADS API (Optional — high-quality monthly PM2.5 backup) ──────────────
# Standard cdsapi reads from C:\Users\<you>\.adsapirc — no env var needed.
# Register at: https://ads.atmosphere.copernicus.eu/
# Format of .adsapirc:
#   url: https://ads.atmosphere.copernicus.eu/api/v2
#   key: UID:API_KEY
CAMS_API_KEY=

# ── OpenStreetMap Overpass API ────────────────────────────────────────────────
# No API key needed. Optionally override the default server if rate limited.
# Mirrors: https://overpass.kumi.systems/api/interpreter
#          https://z.overpass-api.de/api/interpreter
OSM_OVERPASS_URL=
