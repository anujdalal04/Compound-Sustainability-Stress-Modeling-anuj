# Virtual environment
.venv/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Jupyter
.ipynb_checkpoints/

# Mac system files
.DS_Store

# Data folders (DO NOT push large data to GitHub)
data/raw/*
data/processed/*
data/features/*
data/metadata/*

# Keep folder structure
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/features/.gitkeep
!data/metadata/.gitkeep

# Logs
*.log

# Environment / secrets — NEVER commit API keys
.env
.env.*
!.env.example

# Generated reports (large self-contained HTML files)
reports/*.html

# Final H3 panel data (large Parquet files)
data/h3_panel/*
!data/h3_panel/.gitkeep

# Raw parquet files anywhere
*.parquet